# Copy to .env and set values. Used at build time for Vite env injection.

# Optional: use pre-built image instead of building
# DOCKER_IMAGE=your-registry/accordo-frontend:latest

PORT=5001

# Build args (baked into the frontend bundle at build time)
VITE_BACKEND_URL=https://api.example.com
VITE_FRONTEND_URL=https://app.example.com
VITE_ASSEST_URL=https://assets.example.com
